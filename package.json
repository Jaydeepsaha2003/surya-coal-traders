{
  "name": "surya-coal-traders",
  "version": "1.4.0",
  "description": "Local-first desktop app for Surya Coal Traders — trades, ledgers, aging and P&L",
  "main": "dist-electron/main/main.js",
  "author": "Merkatura",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "package": "npm run build && electron-builder --win --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "date-fns": "^2.30.0",
    "drizzle-orm": "^0.30.10",
    "exceljs": "^4.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^18.19.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.20.18",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.447.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^4.5.5",
    "wait-on": "^8.0.1",
    "zod": "^3.23.8"
  },
  "build": {
    "appId": "com.merkatura.suryacoal",
    "productName": "Surya Coal Traders",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Surya Coal Traders",
      "deleteAppDataOnUninstall": false
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
